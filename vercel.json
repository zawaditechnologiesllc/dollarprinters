{
    "outputDirectory": "dist",
    "buildCommand": "npm run build",
    "rewrites": [
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "Cross-Origin-Opener-Policy", "value": "unsafe-none" },
                { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" }
            ]
        }
    ]
}
